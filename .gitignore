import asyncio
import time
import logging
import os
from dotenv import load_dotenv

# ===================== LOAD ENV VARIABLES =====================
load_dotenv()  # loads .env file if present

API_KEY = os.getenv("BINANCE_API_KEY")        # <- Put your API Key here
API_SECRET = os.getenv("BINANCE_API_SECRET")  # <- Put your API Secret here

if not API_KEY or not API_SECRET:
    raise ValueError("API keys not found! Please set BINANCE_API_KEY and BINANCE_API_SECRET in your environment variables or .env file.")

# ===================== BOT IDENTITY =====================
BOT_NAME = "PresleyArbBot"
VERSION = "5.5"
AUTHOR = "Presley Oseyi Okoduwa"

# ===================== LOGGING SETUP =====================
logging.basicConfig(
    filename="opportunities_2026.log",
    level=logging.INFO,
    format="%(asctime)s | %(message)s"
)

# ===================== SOCKET HANDLER =====================
async def handle_socket(msg, client):
    try:
        # ---- your existing logic that defines: best, age ----
        # (Ensure 'best' and 'age' are defined from your trading logic)
        
        if best:
            log_message = (
                f"{BOT_NAME} | {best['path']} | "
                f"{best['profit']:.4f}% | age:{age:.2f}s | "
                f"qty:{best['qty_start_usdt']:.1f}"
            )
            logging.info(log_message)
            print(f"📊 {log_message}")

            asyncio.create_task(execute_trade(client, best))

    except Exception as e:
        print(f"{BOT_NAME} ERROR (socket):", repr(e))

# ===================== BOT ENTRY POINT =====================
async def start():
    # Create Binance client (use testnet=True for testing!)
    client = await AsyncClient.create(API_KEY, API_SECRET)  

    print(f"\n🚀 {BOT_NAME} v{VERSION} — REALISTIC 2026 MODE")
    print(f"👤 Developed by {AUTHOR}")
    print("⚠️ TESTNET RECOMMENDED\n")

    print("Loading step sizes...")
    await load_step_sizes(client)

    print("Discovering pairs...")
    symbols = await discover_tradable_symbols(client)

    global triangles
    triangles = generate_triangles(symbols)
    map_triangles()

    print(f"Generated {len(triangles)} triangles (forward + reverse)")

    triangle_symbols = {sym for tri in triangles for sym in tri}
    streams = [f"{s.lower()}@depth100@100ms" for s in triangle_symbols]

    bm = BinanceSocketManager(client)
    socket = bm.multiplex_socket(streams)

    while True:
        try:
            async with socket as s:
                async for msg in s:
                    await handle_socket(msg, client)

        except Exception as e:
            print(f"{BOT_NAME} reconnecting in 5s...", repr(e))
            await asyncio.sleep(5)

# ===================== RUN BOT =====================
if name == "main":
    asyncio.run(start())